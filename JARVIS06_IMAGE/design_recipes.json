      "template": "<!DOCTYPE html>\n<html lang=\"ko\">\n<head>\n<meta charset=\"UTF-8\">\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;800;900&display=swap\" rel=\"stylesheet\">\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR&display=swap');\n*{margin:0;padding:0;box-sizing:border-box;font-family:'Noto Sans KR',sans-serif}\n.wide-card:empty{display:none!important}\n.mini-row:empty{display:none!important}\n</style>\n</head>\n<body>\n<div style=\"width:1280px;background:var(--soft);color:var(--ink)\">\n\n  <!-- ══ HERO BAND (deep gradient, split accent) ══ -->\n  <div style=\"position:relative;overflow:hidden;padding:54px 60px 58px;background:linear-gradient(135deg,var(--hero0),var(--hero1))\">\n    <div style=\"position:absolute;inset:0;background-image:linear-gradient(#ffffff0d 1px,transparent 1px),linear-gradient(90deg,#ffffff0d 1px,transparent 1px);background-size:44px 44px\"></div>\n    <div style=\"position:absolute;right:-130px;top:-160px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,var(--a1),transparent 62%);opacity:.20\"></div>\n    <div style=\"position:absolute;left:-120px;bottom:-180px;width:460px;height:460px;border-radius:50%;background:radial-gradient(circle,var(--a2),transparent 62%);opacity:.16\"></div>\n    <div style=\"position:relative;display:inline-flex;align-items:center;gap:9px;padding:8px 18px;border:1px solid var(--eyebrow);border-radius:999px;color:var(--eyebrow);font-size:15px;font-weight:800;letter-spacing:.02em\">\n      <span style=\"width:9px;height:9px;border-radius:50%;background:var(--a1);display:inline-block\"></span>\n      <span style=\"width:9px;height:9px;border-radius:50%;background:var(--a2);display:inline-block\"></span>{{EYEBROW}}</div>\n    <div style=\"position:relative;margin:18px 0 10px;color:#fff;font-size:52px;font-weight:900;letter-spacing:-.02em;line-height:1.1\">{{TITLE}}</div>\n    <div style=\"position:relative;color:#aab8d6;font-size:19px;font-weight:500;max-width:900px\">{{SUBTITLE}}</div>\n    <div style=\"position:relative;margin-top:34px\">{{HERO_STATS}}</div>\n  </div>\n\n  <!-- ══ SECTION EYEBROW — signals the head-to-head split ══ -->\n  <div style=\"display:flex;align-items:center;justify-content:center;gap:16px;padding:38px 60px 6px\">\n    <span style=\"height:2px;width:120px;border-radius:2px;background:linear-gradient(90deg,transparent,var(--a1))\"></span>\n    <span style=\"font-size:16px;font-weight:800;letter-spacing:.14em;color:var(--muted)\">좌 · 우 대조</span>\n    <span style=\"height:2px;width:120px;border-radius:2px;background:linear-gradient(90deg,var(--a2),transparent)\"></span>\n  </div>\n\n  <!-- ══ SPLIT COMPARISON PANEL — center divider, 2 columns ══ -->\n  <div style=\"padding:14px 60px 4px\">\n    <div style=\"display:flex;align-items:stretch;position:relative;background:#fff;border:1px solid var(--grid);border-radius:24px;overflow:hidden;box-shadow:0 22px 60px rgba(18,20,58,.12)\">\n\n      <!-- LEFT SIDE (A) -->\n      <div style=\"flex:1 1 0;min-width:0;padding:30px 38px 36px;border-top:6px solid var(--a1)\">\n        <div style=\"display:inline-flex;align-items:center;gap:10px;margin-bottom:18px\">\n          <span style=\"width:34px;height:34px;border-radius:11px;background:var(--a1);color:#fff;font-weight:900;font-size:17px;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 16px rgba(18,20,58,.16)\">A</span>\n          <span style=\"font-size:15px;font-weight:800;letter-spacing:.10em;color:var(--muted)\">기준 A</span>\n        </div>{{CHART_1}}\n      </div>\n\n      <!-- CENTER DIVIDER + VS BADGE -->\n      <div style=\"flex:0 0 74px;position:relative;display:flex;align-items:center;justify-content:center\">\n        <div style=\"position:absolute;top:26px;bottom:26px;left:50%;width:2px;transform:translateX(-50%);background:linear-gradient(var(--a1),var(--a2))\"></div>\n        <div style=\"position:relative;z-index:2;width:58px;height:58px;border-radius:50%;background:linear-gradient(135deg,var(--a1),var(--a2));color:#fff;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:900;letter-spacing:.02em;border:4px solid #fff;box-shadow:0 8px 22px rgba(18,20,58,.22)\">VS</div>\n      </div>\n\n      <!-- RIGHT SIDE (B) -->\n      <div style=\"flex:1 1 0;min-width:0;padding:30px 38px 36px;border-top:6px solid var(--a2)\">\n        <div style=\"display:inline-flex;align-items:center;gap:10px;margin-bottom:18px\">\n          <span style=\"width:34px;height:34px;border-radius:11px;background:var(--a2);color:#fff;font-weight:900;font-size:17px;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 16px rgba(18,20,58,.16)\">B</span>\n          <span style=\"font-size:15px;font-weight:800;letter-spacing:.10em;color:var(--muted)\">기준 B</span>\n        </div>{{CHART_2}}\n      </div>\n\n    </div>\n  </div>\n\n  <!-- ══ FULL-WIDTH SUPPORTING CHART (collapses if empty) ══ -->\n  <section class=\"wide-card\" style=\"margin:24px 60px 0;background:#fff;border:1px solid var(--grid);border-radius:24px;padding:30px 40px;box-shadow:0 18px 50px rgba(18,20,58,.08)\">{{CHART_3}}</section>\n\n  <!-- ══ MINI CARD ROW (collapses if empty) ══ -->\n  <div class=\"mini-row\" style=\"margin:24px 60px 0\">{{MINI_CARDS}}</div>\n\n  <!-- ══ FOOTER ══ -->\n  <div style=\"margin-top:10px;padding:22px 60px 30px;display:flex;align-items:center;justify-content:space-between;color:var(--muted);font-size:14px;font-weight:600\">\n    <span>{{SOURCE}}</span><span style=\"font-weight:800;color:var(--ink)\">{{BRAND}}</span>\n  </div>\n\n</div>\n</body>\n</html>",
