    {
      "id": "dashboard-grid",
      "name": "대시보드 그리드",
      "aesthetic": "상단 KPI 밴드 + 2열 차트 그리드",
      "hero": [
        "#0a1730",
        "#16345f"
      ],
      "ink": "#0f1b33",
      "a1": "#f5b829",
      "a1s": "#ffce54",
      "a2": "#22d3c5",
      "a2s": "#37d6cf",
      "soft": "#eef2f8",
      "muted": "#64748b",
      "eyebrow": "#ffd466",
      "grid": "#e9edf4",
      "eyebrow_label": "대시보드 그리드",
      "hero_texture": "grid",
      "card_radius": 22,
      "template": "<!DOCTYPE html>\n<html lang=\"ko\">\n<head>\n<meta charset=\"UTF-8\">\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR&display=swap');\n*{margin:0;padding:0;box-sizing:border-box;font-family:'Noto Sans KR',sans-serif}\n.page{background:var(--soft);color:var(--ink)}\n.hero{position:relative;overflow:hidden;padding:52px 60px 58px;background:linear-gradient(135deg,var(--hero0),var(--hero1))}\n.tex{position:absolute;inset:0;background-image:linear-gradient(#ffffff0d 1px,transparent 1px),linear-gradient(90deg,#ffffff0d 1px,transparent 1px);background-size:44px 44px}\n.eyebrow-row{position:relative;display:flex;align-items:center;justify-content:space-between}\n.eyebrow{display:inline-flex;align-items:center;gap:9px;padding:9px 18px;border:1px solid var(--eyebrow);border-radius:100px;color:var(--eyebrow);font-size:15px;letter-spacing:.02em}\n.eyebrow::before{content:\"\";width:8px;height:8px;border-radius:100px;background:var(--eyebrow)}\n.tag{display:inline-flex;align-items:center;gap:9px;color:var(--a2s);font-size:14px;letter-spacing:.06em;text-transform:uppercase}\n.tag::before{content:\"\";width:26px;height:2px;border-radius:100px;background:var(--a2)}\n.title{position:relative;margin:22px 0 12px;color:#fff;font-size:50px;line-height:1.12;letter-spacing:-.02em}\n.subtitle{position:relative;color:#a9bad6;font-size:19px;max-width:62%}\n.kpiband{position:relative;margin-top:38px}\n.kpiband:empty{display:none}\n.body{padding:36px 60px 12px}\n.ministrip{margin-bottom:30px}\n.ministrip:empty{display:none}\n.gridhead{display:flex;align-items:center;gap:16px;margin:2px 0 22px}\n.gridhead .rule{flex:1;height:1px;background:var(--grid)}\n.gridhead .lbl{display:inline-flex;align-items:center;gap:10px;color:var(--muted);font-size:15px;letter-spacing:.02em}\n.gridhead .dot{width:13px;height:13px;border-radius:5px;background:linear-gradient(135deg,var(--a1),var(--a2))}\n.grid{display:grid;grid-template-columns:1fr 1fr;gap:28px}\n.card{background:#fff;border-radius:22px;padding:30px 34px;border:1px solid var(--grid);box-shadow:0 18px 46px #0f1b3317}\n.card:empty{display:none}\n.card.wide{grid-column:1 / -1;margin-top:28px}\n.footer{margin-top:28px;padding:20px 60px 30px;border-top:1px solid var(--grid);display:flex;align-items:center;justify-content:space-between;color:var(--muted);font-size:14px}\n.footer .src{display:inline-flex;align-items:center;gap:10px}\n.footer .src::before{content:\"\";width:9px;height:9px;border-radius:100px;background:var(--a1)}\n</style>\n</head>\n<body>\n<div class=\"page\" style=\"width:1280px\">\n  <header class=\"hero\">\n    <div class=\"tex\"></div>\n    <div style=\"position:absolute;right:-130px;top:-160px;width:480px;height:480px;border-radius:9999px;background:radial-gradient(circle,var(--a1),transparent 62%);opacity:.16\"></div>\n    <div style=\"position:absolute;left:-90px;bottom:-150px;width:360px;height:360px;border-radius:9999px;background:radial-gradient(circle,var(--a2),transparent 60%);opacity:.14\"></div>\n    <div class=\"eyebrow-row\">\n      <span class=\"eyebrow\" style=\"font-weight:700\">{{EYEBROW}}</span>\n      <span class=\"tag\" style=\"font-weight:700\">{{BRAND}}</span>\n    </div>\n    <h1 class=\"title\" style=\"font-weight:900\">{{TITLE}}</h1>\n    <p class=\"subtitle\" style=\"font-weight:500\">{{SUBTITLE}}</p>\n    <div class=\"kpiband\">{{HERO_STATS}}</div>\n  </header>\n  <main class=\"body\">\n    <div class=\"ministrip\">{{MINI_CARDS}}</div>\n    <div class=\"gridhead\"><span class=\"lbl\" style=\"font-weight:700\"><span class=\"dot\"></span>데이터 그리드</span><span class=\"rule\"></span></div>\n    <div class=\"grid\">\n      <div class=\"card\">{{CHART_1}}</div>\n      <div class=\"card\">{{CHART_2}}</div>\n    </div>\n    <div class=\"card wide\">{{CHART_3}}</div>\n  </main>\n  <footer class=\"footer\">\n    <span class=\"src\">{{SOURCE}}</span>\n    <span style=\"font-weight:800;color:var(--ink)\">{{BRAND}}</span>\n  </footer>\n</div>\n</body>\n</html>",
      "source": "seed-layout",
      "created": "2026-07-05"
    },
    {
      "id": "magazine-feature",
      "name": "매거진 피처",
      "aesthetic": "비대칭 에디토리얼 — 큰 히어로 스탯 좌측, 차트 우측 흐름",
      "hero": [
        "#1a1420",
        "#3a2140"
      ],
      "ink": "#241a2b",
      "a1": "#ff6b5e",
      "a1s": "#ff8a7d",
      "a2": "#22b8a6",
      "a2s": "#3ad0be",
      "soft": "#f6f1f4",
      "muted": "#6b6472",
      "eyebrow": "#ffb3aa",
      "grid": "#efe8ee",
      "eyebrow_label": "매거진 피처",
      "hero_texture": "diagonal",
      "card_radius": 22,
      "template": "<!DOCTYPE html>\n<html lang=\"ko\">\n<head>\n<meta charset=\"UTF-8\">\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;800;900&display=swap');\n*{margin:0;padding:0;box-sizing:border-box;font-family:'Noto Sans KR',sans-serif}\n/* 좁은 피처 레일에서 히어로 스탯 슬롯을 세로 스택으로 재배치 (인라인 불가 — 자식 선택자) */\n.hero-rail-stats > div{flex-direction:column !important;gap:18px !important}\n.hero-rail-stats > div > div{flex:0 0 auto !important}\n/* 데이터 없는 슬롯은 접힘 (인라인 불가 — :empty 의사클래스) */\n.chart-block:empty{display:none}\n.mini-strip:empty{display:none}\n</style>\n</head>\n<body>\n<div style=\"width:1280px;background:var(--soft);overflow:hidden;position:relative\">\n\n  <!-- ── 비대칭 그리드: 좌측 피처 레일(어두움) / 우측 차트 흐름(밝음) ── -->\n  <div style=\"display:grid;grid-template-columns:500px 780px;align-items:stretch\">\n\n    <!-- 좌측 피처 레일 : 히어로 그라디언트 위 큰 스탯 -->\n    <aside style=\"position:relative;overflow:hidden;padding:56px 44px 48px;background:linear-gradient(155deg,var(--hero0),var(--hero1))\">\n      <div style=\"position:absolute;inset:0;pointer-events:none;background-image:repeating-linear-gradient(48deg,rgba(255,255,255,.05) 0 1px,transparent 1px 20px)\"></div>\n      <div style=\"position:absolute;left:-120px;bottom:-160px;width:440px;height:440px;border-radius:50%;background:radial-gradient(circle,var(--a1),transparent 62%);opacity:.22\"></div>\n      <div style=\"position:relative\">\n        <div style=\"display:inline-flex;align-items:center;gap:9px;padding:8px 16px;border:1px solid var(--eyebrow);border-radius:999px;color:var(--eyebrow);font-size:15px;font-weight:800;letter-spacing:.02em;background:rgba(255,255,255,.06)\">\n          <span style=\"width:9px;height:9px;border-radius:3px;background:var(--a1);display:block\"></span>{{EYEBROW}}</div>\n        <div style=\"margin-top:26px;padding-left:20px;border-left:5px solid var(--a1)\">\n          <div style=\"color:#fff;font-size:52px;font-weight:900;letter-spacing:-.03em;line-height:1.08\">{{TITLE}}</div>\n          <div style=\"margin-top:14px;color:rgba(255,255,255,.72);font-size:18px;font-weight:400;line-height:1.5\">{{SUBTITLE}}</div>\n        </div>\n        <div style=\"height:1px;background:rgba(255,255,255,.14);margin:34px 0 22px\"></div>\n        <div style=\"display:flex;align-items:center;gap:12px;color:var(--a2s);font-size:15px;font-weight:800;letter-spacing:.06em;margin-bottom:20px\">\n          핵심 지표<span style=\"flex:1;height:1px;background:rgba(255,255,255,.10)\"></span></div>\n        <div class=\"hero-rail-stats\">{{HERO_STATS}}</div>\n        <div style=\"margin-top:30px;color:rgba(255,255,255,.55);font-size:14px;font-weight:600\">{{BRAND}}</div>\n      </div>\n    </aside>\n\n    <!-- 우측 차트 흐름 : 밝은 배경 위 세로 리딩 플로우 -->\n    <main style=\"padding:52px 52px 44px;position:relative\">\n      <div style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:8px\">\n        <span style=\"font-size:15px;font-weight:800;color:var(--muted);letter-spacing:.10em\">데이터 리포트</span>\n        <span style=\"display:inline-flex;align-items:center;gap:8px;padding:7px 15px;border-radius:999px;background:var(--ink);color:#fff;font-size:14px;font-weight:800\">\n          <span style=\"width:8px;height:8px;border-radius:50%;background:var(--a2s);display:block\"></span>{{BRAND}}</span>\n      </div>\n      <div style=\"height:3px;width:64px;border-radius:3px;background:var(--a1);margin:14px 0 10px\"></div>\n      <div class=\"chart-block\" style=\"background:#fff;border-radius:22px;padding:30px 32px;margin-top:22px;border:1px solid var(--grid);border-left:5px solid var(--a2);box-shadow:0 16px 40px rgba(20,16,26,.06)\">{{CHART_1}}</div>\n      <div class=\"chart-block\" style=\"background:#fff;border-radius:22px;padding:30px 32px;margin-top:22px;border:1px solid var(--grid);border-left:5px solid var(--a1);box-shadow:0 16px 40px rgba(20,16,26,.06)\">{{CHART_2}}</div>\n      <div class=\"chart-block\" style=\"background:#fff;border-radius:22px;padding:30px 32px;margin-top:22px;border:1px solid var(--grid);border-left:5px solid var(--a2);box-shadow:0 16px 40px rgba(20,16,26,.06)\">{{CHART_3}}</div>\n    </main>\n  </div>\n\n  <!-- 전폭 보조 카드 스트립 -->\n  <div class=\"mini-strip\" style=\"padding:8px 52px 6px\">{{MINI_CARDS}}</div>\n\n  <!-- 푸터 -->\n  <div style=\"display:flex;align-items:center;justify-content:space-between;padding:22px 52px 30px;margin-top:14px;border-top:1px solid var(--grid)\">\n    <span style=\"color:var(--muted);font-size:14px;font-weight:600\">{{SOURCE}}</span>\n    <span style=\"color:var(--ink);font-size:15px;font-weight:800;letter-spacing:.02em\">{{BRAND}}</span>\n  </div>\n</div>\n</body>\n</html>",
      "source": "seed-layout",
      "created": "2026-07-05"
    },
    {
      "id": "big-number-hero",
      "name": "빅넘버 히어로",
      "aesthetic": "초대형 단일 히어로 스탯 지배 + 하단 보조 차트",
      "hero": [
        "#0c1f14",
        "#173a24"
      ],
      "ink": "#123020",
      "a1": "#f97316",
      "a1s": "#fb923c",
      "a2": "#0ea5e9",
      "a2s": "#38bdf8",
      "soft": "#eef4ef",
      "muted": "#5a6b5f",
      "eyebrow": "#ffc27a",
      "grid": "#e3ede6",
      "eyebrow_label": "빅넘버 히어로",
      "hero_texture": "grid",
      "card_radius": 24,
      "template": "<!DOCTYPE html>\n<html lang=\"ko\">\n<head>\n<meta charset=\"UTF-8\">\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR&display=swap');\n*{margin:0;padding:0;box-sizing:border-box;font-family:'Noto Sans KR',sans-serif}\n</style>\n</head>\n<body>\n<div style=\"width:1280px;background:var(--soft);position:relative;overflow:hidden\">\n\n  <!-- ═══════════ HERO BAND — 초대형 단일 히어로 스탯 지배 ═══════════ -->\n  <div style=\"position:relative;overflow:hidden;padding:58px 64px 64px;background:linear-gradient(135deg,var(--hero0),var(--hero1))\">\n\n    <!-- 텍스처: 미세 그리드 -->\n    <div style=\"position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.045) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.045) 1px,transparent 1px);background-size:46px 46px\"></div>\n    <!-- 대형 장식 아크 (우상단) — 히어로 드라마 -->\n    <div style=\"position:absolute;right:-160px;top:-190px;width:560px;height:560px;border-radius:50%;background:radial-gradient(circle,var(--a1) 0%,transparent 62%);opacity:.20\"></div>\n    <div style=\"position:absolute;right:-40px;bottom:-150px;width:360px;height:360px;border-radius:50%;background:radial-gradient(circle,var(--a2) 0%,transparent 60%);opacity:.16\"></div>\n\n    <!-- 헤더 행: 아이브로우 + 브랜드 -->\n    <div style=\"position:relative;display:flex;align-items:center;justify-content:space-between\">\n      <div style=\"display:inline-flex;align-items:center;gap:10px;padding:9px 18px;border:1px solid var(--eyebrow);border-radius:999px;color:var(--eyebrow);font-size:15px;font-weight:700;letter-spacing:.02em\">\n        <span style=\"width:9px;height:9px;border-radius:50%;background:var(--eyebrow);box-shadow:0 0 0 4px rgba(255,255,255,.10)\"></span>\n        {{EYEBROW}}\n      </div>\n      <div style=\"color:rgba(255,255,255,.55);font-size:14px;font-weight:700;letter-spacing:.10em;text-transform:uppercase\">{{BRAND}}</div>\n    </div>\n\n    <!-- 타이틀 + 서브 -->\n    <h1 style=\"position:relative;margin:22px 0 12px;color:#fff;font-size:56px;font-weight:900;letter-spacing:-.03em;line-height:1.06;max-width:920px\">{{TITLE}}</h1>\n    <div style=\"position:relative;color:rgba(255,255,255,.74);font-size:20px;font-weight:500;max-width:820px;line-height:1.5\">{{SUBTITLE}}</div>\n\n    <!-- 히어로 스탯: 초대형 단일 넘버가 지배 -->\n    <div style=\"position:relative;display:flex;align-items:center;gap:12px;margin:34px 0 16px\">\n      <span style=\"width:34px;height:3px;border-radius:2px;background:var(--a1s)\"></span>\n      <span style=\"color:rgba(255,255,255,.62);font-size:15px;font-weight:700;letter-spacing:.14em;text-transform:uppercase\">핵심 지표 · KEY METRIC</span>\n    </div>\n    <div style=\"position:relative\">{{HERO_STATS}}</div>\n\n  </div>\n\n  <!-- ═══════════ 하단 보조 차트 섹션 ═══════════ -->\n  <div style=\"padding:46px 64px 10px;background:var(--soft)\">\n\n    <!-- 섹션 라벨 -->\n    <div style=\"display:flex;align-items:center;gap:14px;margin-bottom:24px\">\n      <span style=\"width:12px;height:12px;border-radius:4px;background:var(--a1)\"></span>\n      <span style=\"color:var(--ink);font-size:20px;font-weight:800;letter-spacing:-.01em\">보조 지표</span>\n      <span style=\"color:var(--muted);font-size:14px;font-weight:700;letter-spacing:.12em;text-transform:uppercase\">Supporting Data</span>\n      <span style=\"flex:1;height:1px;background:var(--grid)\"></span>\n    </div>\n\n    <!-- 1차 보조 차트 (전폭) -->\n    <div style=\"background:#fff;border-radius:24px;padding:32px 36px;border:1px solid var(--grid);box-shadow:0 20px 48px rgba(18,42,83,.09)\">{{CHART_1}}</div>\n\n    <!-- 2·3차 보조 차트 (공유 카드 — 빈 슬롯이면 자동 축소) -->\n    <div style=\"background:#fff;border-radius:24px;padding:32px 36px;margin-top:24px;border:1px solid var(--grid);box-shadow:0 20px 48px rgba(18,42,83,.09);display:flex;flex-direction:column;gap:30px\">{{CHART_2}}{{CHART_3}}</div>\n\n    <!-- 보조 통계 카드 행 -->\n    <div style=\"margin-top:24px\">{{MINI_CARDS}}</div>\n\n  </div>\n\n  <!-- ═══════════ 푸터 ═══════════ -->\n  <div style=\"padding:22px 64px 30px;background:var(--soft);display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--grid)\">\n    <span style=\"color:var(--muted);font-size:14px;font-weight:600\">{{SOURCE}}</span>\n    <span style=\"color:var(--ink);font-size:14px;font-weight:800;letter-spacing:.02em\">{{BRAND}}</span>\n  </div>\n\n</div>\n</body>\n</html>",
      "source": "seed-layout",
      "created": "2026-07-05"
    },
    {
      "id": "comparison-split",
