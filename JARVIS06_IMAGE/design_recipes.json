      "template": "<!DOCTYPE html>\n<html lang=\"ko\">\n<head>\n<meta charset=\"utf-8\">\n<link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700;800;900&display=swap\">\n<style>*{margin:0;padding:0;box-sizing:border-box}.hero-stats:empty{display:none}.mini:empty{display:none}.sec:empty{display:none}</style>\n</head>\n<body style=\"font-family:'Noto Sans KR',sans-serif;background:var(--soft);-webkit-font-smoothing:antialiased\">\n<div style=\"width:1280px;background:var(--soft);overflow:hidden\">\n\n  <!-- ── 헤더 밴드 ─────────────────────────────── -->\n  <div style=\"position:relative;overflow:hidden;padding:52px 64px 46px;background:linear-gradient(135deg,var(--hero0),var(--hero1))\">\n    <div style=\"position:absolute;inset:0;background-image:linear-gradient(#ffffff08 1px,transparent 1px),linear-gradient(90deg,#ffffff08 1px,transparent 1px);background-size:44px 44px\"></div>\n    <div style=\"position:absolute;right:-120px;top:-160px;width:460px;height:460px;border-radius:50%;background:radial-gradient(circle,var(--a2),transparent 62%);opacity:.16\"></div>\n    <div style=\"position:relative\">\n      <div style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:26px\">\n        <span style=\"display:inline-flex;align-items:center;gap:9px;padding:8px 16px;border-radius:999px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.16);font-size:15px;font-weight:800;letter-spacing:.04em;color:var(--eyebrow)\"><span style=\"width:9px;height:9px;border-radius:50%;background:var(--a1);display:inline-block\"></span>{{EYEBROW}}</span>\n        <span style=\"font-size:15px;font-weight:700;color:#c3d3cf\">{{BRAND}}</span>\n      </div>\n      <div style=\"font-size:52px;font-weight:900;letter-spacing:-.03em;line-height:1.08;color:#fff;max-width:1000px\">{{TITLE}}</div>\n      <div style=\"width:76px;height:6px;border-radius:4px;margin:20px 0 16px;background:linear-gradient(90deg,var(--a1),var(--a1s))\"></div>\n      <div style=\"font-size:20px;font-weight:500;line-height:1.5;color:#b9cbc6;max-width:880px\">{{SUBTITLE}}</div>\n      <div class=\"hero-stats\" style=\"margin-top:34px\">{{HERO_STATS}}</div>\n    </div>\n  </div>\n\n  <!-- ── 본문 세로 스택 ───────────────────────── -->\n  <div style=\"padding:38px 64px 30px\">\n    <div class=\"mini\" style=\"margin-bottom:34px\">{{MINI_CARDS}}</div>\n    <section class=\"sec\" style=\"background:linear-gradient(var(--a1),var(--a2)) 0 0/7px 100% no-repeat,#fff;border:1px solid var(--grid);border-radius:20px;padding:30px 34px 30px 40px;margin-bottom:26px;box-shadow:0 16px 44px rgba(14,43,40,.07);overflow:hidden\">{{CHART_1}}</section>\n    <section class=\"sec\" style=\"background:linear-gradient(var(--a1),var(--a2)) 0 0/7px 100% no-repeat,#fff;border:1px solid var(--grid);border-radius:20px;padding:30px 34px 30px 40px;margin-bottom:26px;box-shadow:0 16px 44px rgba(14,43,40,.07);overflow:hidden\">{{CHART_2}}</section>\n    <section class=\"sec\" style=\"background:linear-gradient(var(--a1),var(--a2)) 0 0/7px 100% no-repeat,#fff;border:1px solid var(--grid);border-radius:20px;padding:30px 34px 30px 40px;margin-bottom:26px;box-shadow:0 16px 44px rgba(14,43,40,.07);overflow:hidden\">{{CHART_3}}</section>\n  </div>\n\n  <!-- ── 출처 푸터 ─────────────────────────────── -->\n  <div style=\"display:flex;align-items:center;justify-content:space-between;padding:22px 64px 40px;border-top:1px solid var(--grid);margin-top:8px\">\n    <span style=\"display:inline-flex;align-items:center;gap:10px;font-size:15px;font-weight:600;color:var(--muted)\"><span style=\"width:18px;height:18px;border-radius:5px;background:linear-gradient(135deg,var(--a1),var(--a2));display:inline-block\"></span>{{SOURCE}}</span>\n    <span style=\"font-size:14px;font-weight:700;letter-spacing:.06em;color:var(--muted);text-transform:uppercase\">{{BRAND}}</span>\n  </div>\n\n</div>\n</body>\n</html>",
