      "template": "<!DOCTYPE html>\n<html lang=\"ko\">\n<head>\n<meta charset=\"UTF-8\">\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR&display=swap');\n*{margin:0;padding:0;box-sizing:border-box;font-family:'Noto Sans KR',sans-serif}\n.slot-c3:empty,.slot-mini:empty,.slot-hero:empty,.slot-cc:empty{display:none}\n</style>\n</head>\n<body>\n<div style=\"width:1280px;background:var(--soft);overflow:hidden\">\n\n  <!-- ═══ BOLD BANNER ═══ -->\n  <div style=\"position:relative;overflow:hidden;padding:54px 60px 58px;background:linear-gradient(135deg,var(--hero0),var(--hero1));border-bottom:10px solid var(--a1)\">\n    <div style=\"position:absolute;right:-90px;top:-120px;width:440px;height:440px;background:radial-gradient(circle,var(--a2),transparent 62%);opacity:.20\"></div>\n    <div style=\"position:absolute;left:0;top:0;bottom:0;width:14px;background:var(--a2)\"></div>\n    <div style=\"position:relative\">\n      <div style=\"display:inline-flex;align-items:center;gap:10px;padding:9px 20px;background:var(--a1);color:var(--ink);border:4px solid var(--soft);box-shadow:7px 7px 0 var(--a2);text-transform:uppercase;letter-spacing:.14em\">\n        <span style=\"width:12px;height:12px;background:var(--ink);display:inline-block\"></span>\n        <span style=\"font-size:16px;font-weight:900\">{{EYEBROW}}</span>\n      </div>\n      <h1 style=\"color:var(--soft);font-size:60px;font-weight:900;letter-spacing:-.02em;line-height:1.04;margin:24px 0 12px;max-width:1000px\">{{TITLE}}</h1>\n      <div style=\"display:inline-block;color:var(--ink);background:var(--eyebrow);font-size:20px;font-weight:800;padding:8px 18px;box-shadow:6px 6px 0 var(--hero0)\">{{SUBTITLE}}</div>\n    </div>\n    <div class=\"slot-hero\" style=\"position:relative;margin-top:38px\">{{HERO_STATS}}</div>\n  </div>\n\n  <!-- ═══ BODY — 카드 2열 ═══ -->\n  <div style=\"padding:44px 60px 20px\">\n\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:30px;align-items:start\">\n      <div class=\"slot-cc\" style=\"background:#fff;border:5px solid var(--ink);border-radius:20px;box-shadow:12px 12px 0 var(--ink);padding:30px 32px;border-top:14px solid var(--a1)\">{{CHART_1}}</div>\n      <div class=\"slot-cc\" style=\"background:#fff;border:5px solid var(--ink);border-radius:20px;box-shadow:12px 12px 0 var(--ink);padding:30px 32px;border-top:14px solid var(--a2)\">{{CHART_2}}</div>\n    </div>\n\n    <div class=\"slot-c3\" style=\"margin-top:30px;background:#fff;border:5px solid var(--ink);border-radius:20px;box-shadow:12px 12px 0 var(--ink);padding:30px 32px;border-top:14px solid var(--eyebrow)\">{{CHART_3}}</div>\n\n    <div class=\"slot-mini\" style=\"margin-top:30px\">{{MINI_CARDS}}</div>\n  </div>\n\n  <!-- ═══ FOOTER ═══ -->\n  <div style=\"margin:26px 60px 34px;padding:20px 26px;background:var(--ink);border-radius:20px;display:flex;align-items:center;justify-content:space-between\">\n    <span style=\"color:var(--soft);font-size:15px;font-weight:600;opacity:.85\">{{SOURCE}}</span>\n    <span style=\"color:var(--a1);font-size:16px;font-weight:900;letter-spacing:.04em\">{{BRAND}}</span>\n  </div>\n\n</div>\n</body>\n</html>",
