# ── JARVIS Agent 환경변수 템플릿 ──────────────────────────────────
# 이 파일을 복사해서 .env 로 이름 변경 후 값을 채우세요.
# cp .env.example .env

# ── Claude / Anthropic ────────────────────────────────────────────
ANTHROPIC_ORG_ID=

# ── 네이버 블로그 ─────────────────────────────────────────────────
NV_URL=https://blog.naver.com/YOUR_BLOG_ID
NV_USERNAME=YOUR_NAVER_ID
NV_PASSWORD=YOUR_NAVER_PASSWORD
NAVER_CLIENT_ID=        # developers.naver.com 에서 발급 (DataLab API)
NAVER_CLIENT_SECRET=    # 동상

# ── 티스토리 블로그 ───────────────────────────────────────────────
TS_URL=https://YOUR_BLOG.tistory.com
TS_USERNAME=YOUR_TISTORY_ID
TS_PASSWORD=YOUR_TISTORY_PASSWORD
TS_COOKIE=              # 티스토리 로그인 후 F12 → Application → TSSESSION 쿠키값

# ── 텔레그램 봇 ───────────────────────────────────────────────────
TELEGRAM_TOKEN=         # @BotFather 에서 발급
TELEGRAM_CHAT_ID=       # 봇과 대화 후 getUpdates 로 확인

# ── 이미지 생성 API ───────────────────────────────────────────────
GOOGLE_AI_API_KEY=      # aistudio.google.com 에서 발급 (Gemini 이미지)
BING_COOKIE=            # bing.com 로그인 후 쿠키 _U 값
HUGGINGFACE_API_KEY=    # huggingface.co 에서 발급 (FLUX 폴백)

# ── 경제 데이터 API ───────────────────────────────────────────────
BOK_ECOS_KEY=           # 한국은행 ECOS API (ecos.bok.or.kr)
DART_API_KEY=           # 금융감독원 DART API (opendart.fss.or.kr)
KOSIS_API_KEY=          # 통계청 KOSIS API (kosis.kr)

# ── 기타 ─────────────────────────────────────────────────────────
PM_LLM_AUDIT=false      # true 시 부팅마다 Haiku API 호출 (비용 발생)
