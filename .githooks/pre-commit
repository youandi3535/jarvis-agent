#!/bin/bash
# JARVIS pre-commit 훅 — CLAUDE.md 박제 검증 자동 실행
#
# 설치 (1회):
#   git config core.hooksPath .githooks
#
# 모드:
#   기본       — 경고 출력 후 commit 통과 (점진적 도입)
#   strict     — JARVIS_STRICT=1 환경변수 설정 시 위반 발견하면 차단
#
# 비활성:
#   git commit --no-verify

set -e

ROOT="$(git rev-parse --show-toplevel)"
SCRIPT="$ROOT/shared/precommit_check.py"

if [ ! -f "$SCRIPT" ]; then
    echo "⚠️  precommit_check.py 없음 — 검증 건너뜀"
    exit 0
fi

python3 "$SCRIPT"
status=$?

# ★ 3원칙 상기 (사용자 박제 2026-07-22) — *도구와 무관한* 안전망.
#   CLAUDE.md 는 Claude Code 세션에서만 자동 로드된다. Cowork·다른 편집기·사람이
#   직접 고친 경우엔 안 읽힌다. 커밋은 어떤 도구로 작업하든 반드시 거치므로
#   여기에 두면 *모든 경로* 에서 한 번은 눈에 들어온다.
echo ""
echo "── 커밋 전 3원칙 자가점검 (CLAUDE.md 최상단) ──────────────────"
echo "  ① 단일 진입점 — 같은 로직·상수가 두 곳에 남지 않았는가?"
echo "  ② 동적 설계   — 박은 숫자·목록·경로를 런타임 파생으로 바꿨는가?"
echo "  ③ 모든 글 적용 — 네이버·티스토리 / 경제·테마 4조합 전부 확인했는가?"
echo "────────────────────────────────────────────────────────────"

if [ $status -eq 0 ]; then
    exit 0
fi

echo ""
if [ "${JARVIS_STRICT:-0}" = "1" ]; then
    echo "❌ JARVIS_STRICT=1 — 위반 해결 후 다시 commit"
    echo "    임시 우회: git commit --no-verify"
    exit 1
fi

echo "💡 경고 모드 — commit 진행됨. 차단 활성화: export JARVIS_STRICT=1"
echo "    위반 카테고리 확인: python3 shared/precommit_check.py --list"
exit 0
